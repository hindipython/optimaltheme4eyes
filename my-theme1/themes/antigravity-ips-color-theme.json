  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment", "comment.line", "comment.block"],
      "settings": {
        "foreground": "#7A8A8D",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Documentation Comments",
      "scope": ["comment.documentation", "comment.block.documentation"],
      "settings": {
        "foreground": "#8A9A9D",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords",
      "scope": ["keyword", "keyword.control", "keyword.other", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#D0A0D8"
      }
    },
    {
      "name": "Keyword Control Flow",
      "scope": ["keyword.control.flow", "keyword.control.return", "keyword.control.conditional"],
      "settings": {
        "foreground": "#FF8B7A"
      }
    },
    {
      "name": "Strings",
      "scope": ["string", "string.quoted", "string.unquoted", "punctuation.definition.string"],
      "settings": {
        "foreground": "#B8E68A"
      }
    },
    {
      "name": "String Escape",
      "scope": ["constant.character.escape", "string.escape"],
      "settings": {
        "foreground": "#70C8C8"
      }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric", "number", "constant.language"],
      "settings": {
        "foreground": "#E8A860"
      }
    },
    {
      "name": "Booleans and Null",
      "scope": ["constant.language.boolean", "constant.language.null", "constant.language.true", "constant.language.false", "constant.language.undefined"],
      "settings": {
        "foreground": "#FF8B7A"
      }
    },
    {
      "name": "Variables",
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#E0E8F0"
      }
    },
    {
      "name": "Variable Parameter",
      "scope": ["variable.parameter", "parameter"],
      "settings": {
        "foreground": "#E0E8F0"
      }
    },
    {
      "name": "Variable Property",
      "scope": ["variable.other.property", "variable.other.object.property", "meta.property"],
      "settings": {
        "foreground": "#B8E68A"
      }
    },
    {
      "name": "Functions and Methods",
      "scope": ["entity.name.function", "support.function", "meta.function-call"],
      "settings": {
        "foreground": "#79C4FF"
      }
    },
    {
      "name": "Classes and Types",
      "scope": ["entity.name.class", "entity.name.type", "support.class", "support.type"],
      "settings": {
        "foreground": "#5FC4A0"
      }
    },
    {
      "name": "Interfaces",
      "scope": ["entity.name.interface", "entity.name.type.interface"],
      "settings": {
        "foreground": "#5FC4A0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Decorators",
      "scope": ["meta.decorator", "punctuation.decorator", "storage.type.annotation"],
      "settings": {
        "foreground": "#FF8B7A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Namespaces and Modules",
      "scope": ["entity.name.namespace", "entity.name.module"],
      "settings": {
        "foreground": "#F0D890"
      }
    },
    {
      "name": "Punctuation Brackets",
      "scope": ["punctuation.bracket", "punctuation.definition.bracket", "punctuation.section"],
      "settings": {
        "foreground": "#9A9A9A"
      }
    },
    {
      "name": "Punctuation Separator",
      "scope": ["punctuation.separator", "punctuation.accessor"],
      "settings": {
        "foreground": "#7A7A7A"
      }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator", "punctuation.operator"],
      "settings": {
        "foreground": "#E0E8F0"
      }
    },
    {
      "name": "Tags (HTML/JSX)",
      "scope": ["entity.name.tag", "meta.tag"],
      "settings": {
        "foreground": "#FF8B7A"
      }
    },
    {
      "name": "Tag Attributes",
      "scope": ["entity.other.attribute-name", "meta.attribute"],
      "settings": {
        "foreground": "#F0D890"
      }
    },
    {
      "name": "CSS Property",
      "scope": ["support.type.property-name.css", "meta.property-name"],
      "settings": {
        "foreground": "#79C4FF"
      }
    },
    {
      "name": "CSS Value",
      "scope": ["support.constant.property-value.css", "meta.property-value"],
      "settings": {
        "foreground": "#B8E68A"
      }
    },
    {
      "name": "CSS Selector",
      "scope": ["entity.name.tag.css", "entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"],
      "settings": {
        "foreground": "#FF8B7A"
      }
    },
    {
      "name": "JSON Key",
      "scope": ["string.quoted.double.json", "support.type.property-name.json"],
      "settings": {
        "foreground": "#B8E68A"
      }
    },
    {
      "name": "YAML Key",
      "scope": ["entity.name.tag.yaml"],
      "settings": {
        "foreground": "#5FC4A0"
      }
    },
    {
      "name": "Markdown Heading",
      "scope": ["markup.heading", "entity.name.section"],
      "settings": {
        "foreground": "#6AAF5A",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Bold",
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#FF8B7A",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Italic",
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#D0A0D8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown Link",
      "scope": ["markup.underline.link", "string.other.link"],
      "settings": {
        "foreground": "#79C4FF"
      }
    },
    {
      "name": "Markdown Code",
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": {
        "foreground": "#B8E68A"
      }
    },
    {
      "name": "Markdown Quote",
      "scope": ["markup.quote"],
      "settings": {
        "foreground": "#7A8A8D",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Git Commit Edits",
      "scope": ["meta.diff.header", "meta.diff.range"],
      "settings": {
        "foreground": "#6AAF5A"
      }
    },
    {
      "name": "Git Line Addition",
      "scope": ["markup.inserted.diff"],
      "settings": {
        "foreground": "#B8E68A"
      }
    },
    {
      "name": "Git Line Deletion",
      "scope": ["markup.deleted.diff"],
      "settings": {
        "foreground": "#FF8B7A"
      }
    },
    {
      "name": "JSX/TSX Component",
      "scope": ["support.class.component", "entity.name.tag.jsx", "entity.name.tag.tsx"],
      "settings": {
        "foreground": "#5FC4A0"
      }
    },
    {
      "name": "Object Keys",
      "scope": ["meta.object-literal.key", "constant.other.object.key"],
      "settings": {
        "foreground": "#B8E68A"
      }
    },
    {
      "name": "Type Aliases",
      "scope": ["entity.name.type.alias"],
      "settings": {
        "foreground": "#5FC4A0"
      }
    },
    {
      "name": "Enum Members",
      "scope": ["variable.other.enummember"],
      "settings": {
        "foreground": "#E8A860"
      }
    }
  ]
}
